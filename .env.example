# Copy to .env on the deploy box (never commit .env).
#
# App-level shared-password gate (the sign-in, shared across Graham's apps).
#   APP_PASSWORD   — the ONE shared password. SET = gate ON; unset/empty = OFF
#                    (no gate; local-dev only, never expose unset).
#   SESSION_SECRET — random key used to SIGN the session cookie (never the
#                    password itself). Generate once, e.g.:
#                        python -c "import secrets; print(secrets.token_hex(32))"
#                    Keep it stable so sessions survive restarts.
APP_PASSWORD=
SESSION_SECRET=

# Anthropic Claude API — powers Super Search (episode identification).
#   Source: 1Password Hopper vault, item `claude-api-key`, field `api_key`.
ANTHROPIC_API_KEY=

# Host/Origin CSRF pin — the public hostname the app is served at.
#   On the box: jjho.graham-williams.com. Leave empty for local dev.
APP_HOST=

# Cloudflare Access JWT verification (deferred; the shared-password gate is the
# active sign-in). If ever gated by CF Access instead, set both from the
# Zero Trust dashboard/API. Left commented + empty = disabled.
# CF_ACCESS_AUD=
# CF_ACCESS_TEAM_DOMAIN=
